{
    "name": "sunnysideup/classname-fixer",
    "description": "Checks all your class names and, if they do not exist (anymore), finds the best new match and updates them.",
    "type": "silverstripe-vendormodule",
    "keywords": [
        "migration",
        "update",
        "upgrade",
        "breaking changes",
        "errors",
        "classnames",
        "class name",
        "dev tool",
        "database",
        "clean"
    ],
    "license": "BSD-3-Clause",
    "require": {
        "silverstripe/framework": "^5.0",
        "silverstripe/admin": "^2.0"
    },
    "require-dev": {},
    "autoload": {
        "psr-4": {
            "Sunnysideup\\ClassNameFixer\\": "src/"
        }
    },
    "extra": {
        "expose": [
            "client/dist"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "bin": [],
    "authors": [
        {
            "name": "Nicolaas Thiemen Francken",
            "email": "modules@sunnysideup.co.nz",
            "role": "lead developer"
        }
    ]
}